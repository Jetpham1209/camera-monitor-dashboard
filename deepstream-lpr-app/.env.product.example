HOST_REPO_ROOT=/home/hicas/camera-monitor-dashboard
LPR_CONTROL_PORT=5190

DEEPSTREAM_PROFILE=jp60-ds70
JETPACK_VERSION=6.0
L4T_VERSION=36.3
CUDA_VER=12.2
TENSORRT_VERSION=8.6
DEEPSTREAM_VERSION=7.0

MODEL_BUILDER_IMAGE=deepstream-lpr-model-builder:local
MODEL_BUILDER_BASE_IMAGE=ultralytics/ultralytics:latest-jetson-jetpack6
MODEL_BUILDER_AUTO_BUILD=1

DOCKER_RUNTIME_ARGS="--runtime nvidia"
DEEPSTREAM_IMAGE=camera-monitor-deepstream-runtime:local
DEEPSTREAM_BASE_IMAGE=nvcr.io/nvidia/deepstream:7.0-triton-multiarch
PYDS_WHEEL_URL=https://github.com/NVIDIA-AI-IOT/deepstream_python_apps/releases/download/v1.1.11/pyds-1.1.11-py3-none-linux_aarch64.whl

DEEPSTREAM_YOLO_REPO=https://github.com/marcoslucianops/DeepStream-Yolo.git
DEEPSTREAM_YOLO_REF=2894babce8e75c49115dbe0c7b516289ed853565
DEEPSTREAM_YOLO_FACE_REPO=https://github.com/marcoslucianops/DeepStream-Yolo-Face.git
DEEPSTREAM_YOLO_FACE_REF=master
DEEPSTREAM_YOLO_SEG_REPO=https://github.com/marcoslucianops/DeepStream-Yolo-Seg.git
DEEPSTREAM_YOLO_SEG_REF=master
DEEPSTREAM_YOLO_POSE_REPO=https://github.com/marcoslucianops/DeepStream-Yolo-Pose.git
DEEPSTREAM_YOLO_POSE_REF=master

# Operator Agent
# Keep disabled or leave OPENAI_API_KEY empty if this Jetson must run fully offline.
AGENT_ENABLED=1
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-4.1-mini
AGENT_TEMPERATURE=
AGENT_MAX_TOKENS=
AGENT_TOP_P=
AGENT_REASONING_EFFORT=
AGENT_BASE_URL=
AGENT_TIME_ZONE=Asia/Bangkok
OPENAI_API_KEY=
AGENT_MEMORY_FILE=runtime/agent-memory.json
AGENT_SETTINGS_FILE=runtime/agent-settings.json
AGENT_SKILLS_DIR=agent-skills
