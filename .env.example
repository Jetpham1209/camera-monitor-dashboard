# Server
PORT=5174
CHECK_INTERVAL_MS=15000
PROBE_TIMEOUT_MS=10000
PING_TIMEOUT_MS=3000

# Telegram alert when a camera goes offline.
# Create a bot with @BotFather, then put the bot token here.
TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token

# Send a message to the bot first, then get your chat id from:
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# Time zone used in Telegram messages.
TELEGRAM_TIME_ZONE=Asia/Bangkok
TELEGRAM_TIMEOUT_MS=10000
